# Copy this to .env.local and fill in your values

# Google OAuth — create credentials at https://console.cloud.google.com/
# Application type: Web application
# Authorized JS origins: http://localhost:3000, https://your-app.vercel.app
# No redirect URIs needed (we use token/implicit flow)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app

# Groq API key (free) — https://console.groq.com
# Optional: if omitted, the Gmail snippet is shown instead of an AI summary
GROQ_API_KEY=gsk_...
